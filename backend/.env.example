# Puerto en el que corre el servidor
PORT=4000

# Cadena de conexion de MongoDB Atlas (ver guia en README.md, seccion 3)
MONGODB_URI=mongodb+srv://usuario:password@cluster0.mongodb.net/lalita?retryWrites=true&w=majority

# Proveedor de IA a usar: openai | gemini | claude
AI_PROVIDER=openai

# Solo necesitas rellenar la clave del proveedor que elijas arriba
OPENAI_API_KEY=
GEMINI_API_KEY=
CLAUDE_API_KEY=

# Dominio del frontend permitido (en local, el de Vite es http://localhost:5173)
CORS_ORIGIN=http://localhost:5173

# Clave secreta para firmar las sesiones (JWT). Genera una propia, por ejemplo con:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
